    "html": "<li class=\"c2 c3 li-bullet-0\"><span class=\"c0\">100,000 flops<br></span></li><li class=\"c2 c3 li-bullet-0\"><span class=\"c0\">10 scan chains → 10,000 flops per chain<br></span></li>"
